{
	"theme": "Adaptive.sublime-theme",
	"rulers":
	[
		70,
		79,
		99
	],
	"always_show_minimap_viewport": true,
	"auto_match_enabled": false,
	"scroll_past_end": true,
	"word_wrap": true,

	"color_scheme": "Mariana.sublime-color-scheme",
	"font_size": 13,

	"spell_check": false,
	"dictionary": "Packages/Language - English/en_GB.dic",

	"ensure_newline_at_eof_on_save": false,

	// Fork of default with "$" excluded so that jQuery
	// variable names like "$foo" in JavaScript can be
	// selected and automatically highlighted.
	//
	// https://forum.sublimetext.com/t/solved-highlighting-variables-including-the-dollar-symbol/3035
	//
	// NOTE: Needs an extra override in JavaScript.sublime-settings
	// https://forum.sublimetext.com/t/double-click-highlight-issue/60936
	"word_separators": "./\\()\"'-:,.;<>~!@#$%^&*|+=[]{}`~?",
	"sub_word_separators": "_",

	"folder_exclude_patterns":
	[
		".git",
		".hg",
		".nyc_output",
		".sass-cache",
		".svn",
		"CVS",
		"coverage",
		"doc/html",
		"docs/_site",
		"docs/coverage",
		"docs/html",
		"docs/js",
		"docs/latex",
		"node_modules"
	],
	"ignored_packages":
	[
		"EditorConfig",
		"Vintage",
	],
	"update_check": true,
	"index_files": true,
	"font_face": "Menlo",
}
